{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nekiro.dev/router-agent-credential/v1",
  "title": "NeKiro Router Invocation Credential Claims v1",
  "$ref": "#/$defs/claims",
  "$defs": {
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "iss",
        "aud",
        "exp",
        "iat",
        "jti",
        "workspaceId",
        "agentId",
        "agentVersion",
        "releaseId",
        "cardDigest",
        "capability",
        "invocationId",
        "rootTaskId",
        "traceId"
      ],
      "properties": {
        "iss": {
          "type": "string",
          "format": "uri",
          "minLength": 1,
          "maxLength": 2048
        },
        "aud": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "string",
            "format": "uri",
            "minLength": 1,
            "maxLength": 2048
          }
        },
        "exp": { "type": "integer", "minimum": 1 },
        "iat": { "type": "integer", "minimum": 1 },
        "jti": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/safeIdentifier" },
        "workspaceId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/workspaceId" },
        "agentId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/agentId" },
        "agentVersion": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/semver" },
        "releaseId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/safeIdentifier" },
        "cardDigest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "capability": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/capabilityId" },
        "invocationId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/invocationId" },
        "rootTaskId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/taskId" },
        "parentInvocationId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/invocationId" },
        "traceId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/traceId" }
      }
    },
    "authenticationError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "enum": ["UNAUTHENTICATED", "FORBIDDEN"] },
        "message": {
          "enum": [
            "Authentication is required.",
            "The managed invocation context is not allowed."
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "code": { "const": "UNAUTHENTICATED" } } },
          "then": { "properties": { "message": { "const": "Authentication is required." } } }
        },
        {
          "if": { "properties": { "code": { "const": "FORBIDDEN" } } },
          "then": { "properties": { "message": { "const": "The managed invocation context is not allowed." } } }
        }
      ]
    }
  }
}
