{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nekiro.dev/agent-card/v0.1",
  "title": "NeKiro Agent Card v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentId",
    "name",
    "description",
    "owner",
    "version",
    "protocol",
    "skills",
    "authentication",
    "permissions",
    "limits"
  ],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "agentId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/agentId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName"],
      "properties": {
        "id": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/ownerId" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    },
    "version": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/semver" },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "version", "transport", "endpoint"],
      "properties": {
        "type": { "const": "a2a" },
        "version": { "const": "0.3.0" },
        "transport": { "const": "JSONRPC" },
        "endpoint": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description", "inputSchema", "outputSchema", "requiredPermissions"],
        "properties": {
          "id": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/capabilityId" },
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "inputSchema": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/jsonObject" },
          "outputSchema": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/jsonObject" },
          "requiredPermissions": {
            "type": "array",
            "uniqueItems": true,
            "items": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/permissionId" }
          }
        }
      }
    },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["none", "api_key", "http_bearer", "oauth2_client_credentials", "mutual_tls"]
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/permissionId" },
          "description": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeoutMs", "maxInputBytes", "maxOutputBytes", "streaming"],
      "properties": {
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 600000 },
        "maxInputBytes": { "type": "integer", "minimum": 1 },
        "maxOutputBytes": { "type": "integer", "minimum": 1 },
        "streaming": { "type": "boolean" }
      }
    }
  }
}
