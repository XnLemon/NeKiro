# Required by deploy/compose.yaml.
# Copy this file to .env and set every value. Empty values are rejected.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Required by the local Control Plane deployment. URL-encode credential
# characters when constructing the PostgreSQL URL. Store only SHA-256 token
# digests in the principal JSON; never put the raw bearer token here.
NEKIRO_COMPOSE_DATABASE_URL=
NEKIRO_DEV_AUTH_PRINCIPALS_JSON=
NEKIRO_AUTH_MODE=development-static
NEKIRO_INTERNAL_AUTH_MODE=development-static
NEKIRO_INTERNAL_DEV_AUTH_PRINCIPALS_JSON=
CONTROL_PLANE_PORT=
# Exact browser origins allowed to call public Gateway routes. Use a
# comma-separated list; wildcard and implicit localhost defaults are rejected.
NEKIRO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEKIRO_ENDPOINT_CHALLENGE_TTL_SECONDS=
NEKIRO_ENDPOINT_VERIFICATION_TIMEOUT_MS=
NEKIRO_ENDPOINT_ALLOWED_PRIVATE_HOSTS_JSON=[]

# Required by the Control Plane's authenticated Router client and invocation
# boundary. The Router URL must be the fixed internal v4 dispatch origin; the
# bearer token is the raw local secret presented to the Router (store only its
# digest in Router principals).
NEKIRO_ROUTER_INTERNAL_URL=
NEKIRO_ROUTER_INTERNAL_BEARER_TOKEN=
NEKIRO_CONTROL_PLANE_INTERNAL_REQUEST_MAX_BYTES=
NEKIRO_GATEWAY_INVOCATION_REQUEST_MAX_BYTES=
NEKIRO_GATEWAY_SSE_EVENT_MAX_BYTES=
NEKIRO_GATEWAY_METADATA_RESPONSE_MAX_BYTES=
NEKIRO_GATEWAY_INVOCATION_DEADLINE_MS=

# Required when running the standalone A2A Router. The Ledger schema must be
# migrated by the deployment-owned step before the Router starts.
NEKIRO_ROUTER_LISTEN_ADDRESS=0.0.0.0:8081
NEKIRO_ROUTER_AGENT_PRINCIPALS_JSON=
NEKIRO_ROUTER_SERVICE_PRINCIPALS_JSON=
NEKIRO_CONTROL_PLANE_RESOLVE_URL=
NEKIRO_CONTROL_PLANE_VERSION_URL=
# Raw token used only by the Router to authenticate to the Control Plane
# internal API. The matching digest belongs in the internal principal JSON.
NEKIRO_CONTROL_PLANE_SERVICE_TOKEN=
NEKIRO_ROUTER_INTERNAL_REQUEST_LIMIT_BYTES=
NEKIRO_ROUTER_AGENT_REQUEST_LIMIT_BYTES=
NEKIRO_ROUTER_CONTROL_PLANE_RESPONSE_LIMIT_BYTES=
NEKIRO_ROUTER_AGENT_RESPONSE_LIMIT_BYTES=
NEKIRO_ROUTER_A2A_EVENT_LIMIT_BYTES=
NEKIRO_ROUTER_SSE_EVENT_LIMIT_BYTES=
NEKIRO_ROUTER_RESOLUTION_DEADLINE_MS=
NEKIRO_ROUTER_AGENT_DEADLINE_MS=
# Router-to-Agent signing has no built-in key, identity, or TTL. Generate an
# Ed25519 key pair and encode the 64-byte private and 32-byte public values as
# unpadded Base64url.
NEKIRO_ROUTER_AGENT_CREDENTIAL_ISSUER=
NEKIRO_ROUTER_AGENT_CREDENTIAL_KEY_ID=
NEKIRO_ROUTER_AGENT_CREDENTIAL_PRIVATE_KEY_BASE64URL=
NEKIRO_ROUTER_AGENT_CREDENTIAL_TTL_SECONDS=
A2A_ROUTER_PORT=

# Runtime A is the only sample that needs a Router Agent binding. The token
# digest is configured in NEKIRO_ROUTER_AGENT_PRINCIPALS_JSON; this raw value
# is supplied only to Runtime A and must never be logged or persisted.
RUNTIME_A_ROUTER_TOKEN=
RUNTIME_A_RESPONSE_LIMIT_BYTES=
RUNTIME_A_EVENT_LIMIT_BYTES=
NEKIRO_AGENT_ROUTER_ISSUER=
NEKIRO_AGENT_ROUTER_KEY_ID=
NEKIRO_AGENT_ROUTER_PUBLIC_KEY_BASE64URL=
